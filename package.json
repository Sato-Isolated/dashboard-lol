{
  "name": "dashboard-lol",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "author": "MindLated",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "rimraf .next",
    "test": "jest",
    "test:specific": "node scripts/runSpecificTests.js",
    "test:specific:ts": "tsx scripts/runSpecificTests.ts",
    "test:specific:watch": "node scripts/runSpecificTests.js --watch",
    "test:components": "jest --testPathPattern=\"(src/features|src/shared).*__tests__.*\\.(test|spec)\\.(ts|tsx)$\"",
    "db:indexes": "tsx src/scripts/createIndexes.ts",
    "db:indexes:drop": "tsx src/scripts/createIndexes.ts drop",
    "test:phase1": "tsx src/scripts/testPhase1.ts",
    "migrate:create-structure": "tsx scripts/migration/createStructure.ts",
    "migrate:move-files": "tsx scripts/migration/moveFiles.ts",
    "migrate:update-imports": "tsx scripts/migration/updateImports.ts",
    "migrate:validate": "tsx scripts/migration/validate.ts",
    "migrate:all": "npm run migrate:create-structure && npm run migrate:move-files && npm run migrate:update-imports && npm run migrate:validate"
  },
  "dependencies": {
    "dotenv-safe": "^9.1.0",
    "glob": "^11.0.2",
    "jest": "^29.7.0",
    "lucide-react": "^0.511.0",
    "mongodb": "^6.16.0",
    "next": "15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "swr": "^2.3.3",
    "ts-jest": "^29.3.4",
    "winston": "^3.17.0",
    "zod": "^3.25.28",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "daisyui": "^5.0.37",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest-environment-jsdom": "^29.7.0",
    "majestic": "^1.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
